---
import Base from '../layouts/Base.astro';

const title = 'Page Not Found | Nascent Strategy';
---

<Base title={title}>
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow reveal">404</span>
      <h1 class="nf-h1 reveal">This page doesn&rsquo;t exist. A revenue leak in your business might.</h1>
      <p class="lede nf-sub reveal">Let&rsquo;s go find it.</p>
      <p class="nf-cta reveal">
        <a class="btn btn-primary" href="/method">
          See the method
          <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </p>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding-top: calc(var(--section-pad) * 1.1);
    padding-bottom: calc(var(--section-pad) * 1.5);
    min-height: 60vh;
  }
  .nf-h1 { font-size: clamp(2.25rem, 4.5vw, 3.5rem); max-width: 20ch; }
  .nf-sub { margin-top: 1.75rem; }
  .nf-cta { margin-top: 2.5rem; }
</style>
