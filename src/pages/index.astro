---
import Base from '../layouts/Base.astro';
import CtaSection from '../components/CtaSection.astro';

const title = 'Nascent Strategy | An AI Consultancy for Operators';
const description =
  'We help businesses find the clarity already inside them, then build what makes it useful. Kansas City, built for anywhere.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://nascentstrategy.com/#org',
      name: 'Nascent Strategy',
      legalName: 'Nascent Strategy LLC',
      url: 'https://nascentstrategy.com',
      slogan:
        'We help businesses find the clarity already inside them, then build what makes it useful.',
      address: { '@type': 'PostalAddress', addressLocality: 'Kansas City', addressCountry: 'US' },
    },
    {
      '@type': 'ProfessionalService',
      name: 'Nascent Strategy',
      url: 'https://nascentstrategy.com',
      description:
        'AI strategy and implementation consultancy for small and medium-sized businesses.',
      areaServed: 'United States',
      parentOrganization: { '@id': 'https://nascentstrategy.com/#org' },
    },
  ],
};

/* Resolve Chart geometry (7.5). Deterministic seeded layout so the
   server-rendered final state and the JS animation share coordinates. */
function mulberry32(seed) {
  return function () {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20260612);
const W = 640;
const H = 400;
const X0 = 48;
const X1 = 584;
const Y0 = 332;
const Y1 = 96;
const CX = 360;
const CY = 320;
function trendPoint(t) {
  const x = (1 - t) * (1 - t) * X0 + 2 * (1 - t) * t * CX + t * t * X1;
  const y = (1 - t) * (1 - t) * Y0 + 2 * (1 - t) * t * CY + t * t * Y1;
  return { x, y };
}
const POINTS = Array.from({ length: 60 }, (_, i) => {
  const t = i / 59;
  const p = trendPoint(t);
  const jitter = (rand() - 0.5) * 14;
  return {
    fx: +p.x.toFixed(1),
    fy: +(p.y + jitter).toFixed(1),
    sx: +(X0 + rand() * (X1 - X0)).toFixed(1),
    sy: +(70 + rand() * (H - 130)).toFixed(1),
    r: rand() > 0.82 ? 3 : 2.2,
  };
});
const TREND_D = `M ${X0} ${Y0} Q ${CX} ${CY} ${X1} ${Y1}`;
---

<Base title={title} description={description} schema={schema}>
  <script is:inline slot="head">
    (function () {
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('resolve-pending');
        setTimeout(function () {
          document.documentElement.classList.remove('resolve-pending');
        }, 2000);
      }
    })();
  </script>

  <!-- HOME-01 Hero -->
  <section class="hero" id="hero">
    <canvas class="hero-field" id="hero-field" aria-hidden="true"></canvas>
    <div class="hero-texture" aria-hidden="true"></div>
    <div class="wrap hero-inner">
      <span class="eyebrow hero-eyebrow hero-support">An AI Consultancy for Operators</span>
      <h1 class="hero-h1 resolve-target" id="resolve-h1">You can feel it before you can prove it.</h1>
      <p class="hero-sub lede hero-support">
        The revenue slipping somewhere you can&rsquo;t pinpoint. The process
        that costs more than it should. The thing your best customers have in
        common that you can&rsquo;t quite name. The clarity is already inside
        your business. We help you find it, decide on it, and build the systems
        that make acting on it easier.
      </p>
      <div class="hero-ctas hero-support">
        <a class="btn btn-primary" href="/contact">
          Book an assessment
          <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a class="btn btn-ghost" href="/method">How it works</a>
      </div>
    </div>
  </section>

  <!-- HOME-02 Problem statement -->
  <section class="section problem">
    <div class="wrap grid problem-grid">
      <h2 class="problem-pull reveal">
        Most businesses already hold the answer. Few have a clean way to reach
        it.
      </h2>
      <div class="problem-copy reveal">
        <p>
          The signal is usually already there, sitting in the sales data, the
          service records, the call notes, the things your team knows but never
          wrote down. What&rsquo;s missing is the connective tissue, the
          structure that turns scattered fragments into a picture you can act
          on. Sometimes that means using AI to read customer behavior you
          couldn&rsquo;t see before. Sometimes it means building a tool that
          takes the friction out of a process everyone has quietly worked
          around for years. Either way the goal is the same: see better, decide
          smarter, and make the right move the easy one.
        </p>
      </div>
    </div>
  </section>

  <hr class="hr wrap-rule" />

  <!-- HOME-03 Method strip -->
  <section class="section method-strip">
    <div class="wrap">
      <span class="eyebrow reveal">The Method</span>
      <h2 class="reveal">See. Solve. Build.</h2>
      <div class="method-cards stagger">
        <a class="card method-card reveal" href="/method#see">
          <span class="method-num mono" aria-hidden="true">01</span>
          <h3 class="method-name">SEE</h3>
          <p>
            We start with the instinct you already have, then go find whether
            the data, the workflows, and the patterns prove it right or point
            to a better answer.
          </p>
          <span class="method-link link-draw">How it works</span>
        </a>
        <a class="card method-card reveal" href="/method#solve">
          <span class="method-num mono" aria-hidden="true">02</span>
          <h3 class="method-name">SOLVE</h3>
          <p>
            We turn what we find into a clear decision: what&rsquo;s worth
            pursuing, what it&rsquo;s worth, and what it would take. Strategy
            first, because the thing you can name isn&rsquo;t always the thing
            you need.
          </p>
          <span class="method-link link-draw">How it works</span>
        </a>
        <a class="card method-card reveal" href="/method#build">
          <span class="method-num mono" aria-hidden="true">03</span>
          <h3 class="method-name">BUILD</h3>
          <p>
            We build what the decision calls for and put it where your team
            works. A view that surfaces the signal, or a tool that removes the
            friction. Measured before and after, so the result is real.
          </p>
          <span class="method-link link-draw">How it works</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HOME-04 Worked example: the signature moment -->
  <section class="section worked">
    <div class="wrap">
      <div class="grid worked-grid">
        <div class="worked-copy">
          <span class="eyebrow reveal">What This Looks Like</span>
          <h2 class="reveal">Two questions. Two kinds of answer.</h2>
          <div class="worked-body reveal">
            <p>
              A semi-truck dealership owner kept asking a small question with a
              whole business inside it: why do people buy trucks from us but
              service them somewhere else? The answer was probably already in
              his records. Somewhere in there was a group of customers who
              bought and stayed, the ones who serviced with the dealership for
              the life of the vehicle. Who were they? How were they sold? What
              did their first service experience look like? Pull those signals
              together and you learn how to turn a one-time buyer into a
              customer who stays. The instinct was right. The data was there.
              The connective tissue was missing.
            </p>
            <p>
              A high-volume restaurant carryout had a different kind of
              problem, the kind everyone had stopped noticing because
              they&rsquo;d adapted around it. Customers parked, walked in,
              waited, and picked up, which meant congestion, pressure on the
              team, and more room for error. The fix wasn&rsquo;t another screen
              nobody wanted. It was a quieter workflow: a text before pickup, a
              check-in link, a stall number, and a back-of-house view showing
              who&rsquo;s in the lot, what they ordered, and what mattered about
              them. The guest stays in the car. The team moves faster.
              Management gets the context to make the moment better.
            </p>
          </div>
          <p class="worked-cta reveal">
            <a class="btn btn-ghost" href="/assessment">See the assessment</a>
          </p>
        </div>

        <figure class="worked-viz on-ink reveal" id="resolve-chart-panel">
          <svg
            id="resolve-chart"
            viewBox={`0 0 ${W} ${H}`}
            role="img"
            aria-label="Chart: scattered records resolving into a clear signal, the kind of clarity the work surfaces and puts a dollar figure on"
          >
            <path
              id="trend-line"
              d={TREND_D}
              fill="none"
              stroke="var(--signal)"
              stroke-width="2"
              stroke-linecap="round"
            />
            <g id="chart-points">
              {POINTS.map((p) => (
                <circle
                  cx={p.fx}
                  cy={p.fy}
                  r={p.r}
                  data-sx={p.sx}
                  data-sy={p.sy}
                  fill="rgba(250, 250, 247, 0.38)"
                />
              ))}
            </g>
            <!-- [PLACEHOLDER metric] Founder to confirm the Resolve Chart figure -->
            <text
              id="chart-figure"
              x={X1}
              y={Y1 - 28}
              text-anchor="end"
              class="chart-figure"
            >$412,000</text>
          </svg>
          <figcaption class="worked-caption mono" id="chart-caption">
            One business needed to see something. The other needed something
            built. Both had been circling it for a while.
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <hr class="hr wrap-rule" />

  <!-- HOME-05 Assessment teaser -->
  <section class="section teaser">
    <div class="wrap grid teaser-grid">
      <div class="teaser-lead">
        <span class="eyebrow reveal">The First Step</span>
        <h2 class="reveal">The Revenue Assessment</h2>
      </div>
      <div class="teaser-body reveal">
        <p>
          Four weeks, fixed fee. We look at your business through both lenses,
          what you can&rsquo;t yet see and where the work gets stuck, then hand
          you a clear picture of where the opportunity is and what it&rsquo;s
          worth. $9,500, no hourly billing. The picture is yours whether you
          build with us or not.
        </p>
        <p class="teaser-cta">
          <a class="btn btn-primary" href="/assessment">
            See what&rsquo;s included
            <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </p>
      </div>
    </div>
  </section>

  <hr class="hr wrap-rule" />

  <!-- HOME-06 Proof teaser -->
  <section class="section teaser">
    <div class="wrap grid teaser-grid">
      <div class="teaser-lead">
        <span class="eyebrow reveal">Proof</span>
        <h2 class="reveal">Measured before. Measured after.</h2>
      </div>
      <div class="teaser-body reveal">
        <p>
          Every engagement records the number before we build, then measures
          what changed. We would rather show you the difference than describe
          it.
        </p>
        <p class="teaser-cta">
          <a class="btn btn-ghost" href="/work">See the proof</a>
        </p>
      </div>
    </div>
  </section>

  <!-- HOME-07 Closing CTA -->
  <CtaSection
    headline="What&rsquo;s the thing you can feel but can&rsquo;t prove yet?"
    body="That&rsquo;s usually where the opportunity is. It&rsquo;s where we start."
    ctaLabel="Book an assessment"
    ctaHref="/contact"
  />
</Base>

<style>
  /* HOME-01 */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: -72px; /* sit beneath the transparent sticky header */
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-field,
  .hero-texture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  /* Static sparse dot-grid texture: shown when JS is off or motion is reduced */
  .hero-texture {
    display: none;
    background-image: radial-gradient(rgba(17, 21, 28, 0.12) 1px, transparent 1px);
    background-size: 28px 28px;
    -webkit-mask-image: radial-gradient(ellipse 75% 65% at 62% 38%, black 30%, transparent 75%);
    mask-image: radial-gradient(ellipse 75% 65% at 62% 38%, black 30%, transparent 75%);
  }
  html.no-js .hero-texture { display: block; }
  @media (prefers-reduced-motion: reduce) {
    .hero-texture { display: block; }
    .hero-field { display: none; }
  }

  .hero-inner {
    position: relative;
    width: 100%;
    padding-top: 72px;
  }
  .hero-eyebrow { margin-bottom: 2rem; }
  .hero-h1 { max-width: 13ch; }
  .hero-h1 :global(.word) { display: inline-block; }
  .hero-sub { margin-top: 2rem; max-width: 56ch; }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-top: 2.75rem;
  }

  /* HOME-02 */
  .problem { padding-top: calc(var(--section-pad) * 0.75); }
  .problem-grid { row-gap: 2.5rem; }
  .problem-pull {
    grid-column: 1 / span 7;
    font-size: clamp(2rem, 3.6vw, 3rem);
    line-height: 1.12;
  }
  .problem-copy {
    grid-column: 9 / -1;
    align-self: end;
    color: var(--slate);
  }

  .wrap-rule {
    max-width: calc(var(--max-width) - 2 * var(--gutter));
    margin-inline: auto;
  }

  /* HOME-03 */
  .method-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 3.5rem;
  }
  .method-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    text-decoration: none;
    min-height: 280px;
  }
  .method-num { color: var(--slate); font-size: 0.8125rem; }
  .method-name {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.0625rem;
    letter-spacing: 0.12em;
    font-variation-settings: normal;
  }
  .method-card p {
    color: var(--slate);
    font-size: 0.9844rem;
    flex-grow: 1;
  }
  .method-link {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--signal);
    width: fit-content;
    background-size: 0% 1px;
  }
  .method-card:hover .method-link { background-size: 100% 1px; }

  /* HOME-04 */
  .worked-grid { row-gap: 3rem; align-items: center; }
  .worked-copy { grid-column: 1 / span 5; }
  .worked-body { margin-top: 1.75rem; color: var(--slate); }
  .worked-cta { margin-top: 2.25rem; }
  .worked-viz {
    grid-column: 7 / -1;
    border-radius: var(--radius);
    padding: 2.5rem 2.5rem 2rem;
    margin: 0;
  }
  .worked-viz svg { width: 100%; height: auto; }
  .chart-figure {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 2.375rem;
    letter-spacing: 0.01em;
    fill: var(--ember);
  }
  .worked-caption {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline-on-ink);
    color: var(--slate-on-ink);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
  }

  /* HOME-05 / HOME-06 */
  .teaser-grid { row-gap: 2rem; }
  .teaser-lead { grid-column: 1 / span 6; }
  .teaser-lead h2 { max-width: 16ch; }
  .teaser-body { grid-column: 8 / -1; color: var(--slate); }
  .teaser-cta { margin-top: 2rem; }

  @media (max-width: 1023px) {
    .problem-pull, .problem-copy, .worked-copy, .worked-viz,
    .teaser-lead, .teaser-body { grid-column: 1 / -1; }
    .method-cards { grid-template-columns: 1fr; }
    .method-card { min-height: 0; }
    .hero { margin-top: -64px; }
    .hero-inner { padding-top: 64px; }
  }
</style>

<script>
  import '../scripts/home.js';
</script>
