---
const { path = '' } = Astro.props;
const links = [
  { href: '/method', label: 'Method' },
  { href: '/assessment', label: 'Assessment' },
  { href: '/work', label: 'Proof' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header" id="site-header">
  <div class="wrap header-bar">
    <a class="wordmark" href="/" aria-label="Nascent Strategy home">
      <span class="wordmark-a">NASCENT</span> <span class="wordmark-b">STRATEGY</span>
    </a>

    <nav class="header-nav" aria-label="Primary">
      {links.map((l) => (
        <a
          class="header-link link-draw"
          href={l.href}
          aria-current={path === l.href ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </nav>

    <a class="btn btn-primary header-cta" href="/contact">
      Book an assessment
      <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <button class="menu-toggle" id="menu-toggle" type="button"
      aria-expanded="false" aria-controls="mobile-menu">
      <span class="visually-hidden">Menu</span>
      <span class="menu-line" aria-hidden="true"></span>
      <span class="menu-line" aria-hidden="true"></span>
    </button>
  </div>
</header>

<div class="mobile-menu on-ink" id="mobile-menu" hidden>
  <nav class="mobile-nav" aria-label="Mobile">
    {links.map((l) => (
      <a class="mobile-link" href={l.href}>{l.label}</a>
    ))}
    <a class="btn btn-primary mobile-cta" href="/contact">
      Book an assessment
      <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: transparent;
    transition: background-color var(--dur-hover) var(--ease-out),
                border-color var(--dur-hover) var(--ease-out),
                backdrop-filter var(--dur-hover) var(--ease-out);
    border-bottom: 1px solid transparent;
  }
  .site-header.is-scrolled {
    background: rgba(250, 250, 247, 0.82);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: var(--hairline);
  }

  .header-bar {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }

  .wordmark {
    display: inline-flex;
    gap: 0.5em;
    text-decoration: none;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.14em;
    line-height: 1;
  }
  .wordmark-a { color: var(--ink); }
  .wordmark-b { color: var(--slate); }

  .header-nav {
    display: flex;
    gap: 2rem;
    margin-left: auto;
  }
  .header-link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ink);
  }
  .header-link[aria-current='page'] {
    background-size: 100% 1px;
    color: var(--signal);
  }

  .header-cta { padding: 0.8125rem 1.25rem; font-size: 0.9375rem; white-space: nowrap; }

  .menu-toggle {
    display: none;
    position: relative;
    z-index: 130;
    width: 44px;
    height: 44px;
    margin-right: -10px;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .menu-line {
    position: absolute;
    left: 11px;
    width: 22px;
    height: 2px;
    background: currentColor;
    color: var(--ink);
    transition: transform 200ms var(--ease-out), background-color 200ms;
  }
  .menu-line:nth-child(2) { top: 18px; }
  .menu-line:nth-child(3) { top: 25px; }
  /* When the overlay is open, lift the header above it so the toggle (now an
     X) stays visible and clickable; keep the bar chrome transparent. */
  body.menu-open .site-header {
    z-index: 130;
    background: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  body.menu-open .wordmark-a { color: var(--paper); }
  body.menu-open .wordmark-b { color: var(--slate-on-ink); }
  body.menu-open .menu-line { color: var(--paper); }
  body.menu-open .menu-line:nth-child(2) { transform: translateY(3.5px) rotate(45deg); }
  body.menu-open .menu-line:nth-child(3) { transform: translateY(-3.5px) rotate(-45deg); }

  /* Mobile menu overlay (7.6) */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: flex;
    align-items: center;
    opacity: 0;
    transition: opacity 250ms var(--ease-out);
  }
  .mobile-menu.is-open { opacity: 1; }
  .mobile-menu.is-closing { transition-duration: 150ms; }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 0 var(--gutter);
    width: 100%;
  }
  .mobile-link {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 80;
    font-weight: 600;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--paper);
    text-decoration: none;
    width: fit-content;
  }
  .mobile-cta { margin-top: 1.5rem; width: fit-content; }

  /* Stagger-resolve: same blur-to-sharp grammar, 60ms stagger, CTA last */
  .mobile-nav > * {
    opacity: 0;
    transform: translateY(12px);
    filter: blur(8px);
    transition: opacity 400ms var(--ease-out),
                transform 400ms var(--ease-out),
                filter 400ms var(--ease-out);
  }
  .mobile-menu.is-open .mobile-nav > * { opacity: 1; transform: none; filter: none; }
  .mobile-menu.is-open .mobile-nav > :nth-child(1) { transition-delay: 60ms; }
  .mobile-menu.is-open .mobile-nav > :nth-child(2) { transition-delay: 120ms; }
  .mobile-menu.is-open .mobile-nav > :nth-child(3) { transition-delay: 180ms; }
  .mobile-menu.is-open .mobile-nav > :nth-child(4) { transition-delay: 240ms; }
  .mobile-menu.is-open .mobile-nav > :nth-child(5) { transition-delay: 300ms; }
  .mobile-menu.is-closing .mobile-nav > * { transition-duration: 120ms; transition-delay: 0ms; }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu, .mobile-nav > * {
      transition: opacity 200ms linear;
      transform: none;
      filter: none;
    }
  }

  @media (max-width: 900px) {
    .header-nav { display: none; }
    .header-cta { margin-left: auto; }
    .menu-toggle { display: block; }
    .header-bar { gap: 1rem; height: 64px; }
  }
  @media (max-width: 480px) {
    .wordmark { font-size: 0.75rem; letter-spacing: 0.1em; gap: 0.4em; }
    .header-cta { padding: 0.6875rem 0.875rem; font-size: 0.8125rem; }
    .header-cta .arrow { display: none; }
    .header-bar { gap: 0.625rem; }
  }
  @media (max-width: 360px) {
    .wordmark-b { display: none; }
  }
</style>
