---
import Base from '../../layouts/Base.astro';
import CtaSection from '../../components/CtaSection.astro';

const title = 'Proof | Nascent Strategy';
const description =
  'Measured before. Measured after. Every Nascent Strategy engagement ships with its own evidence.';
---

<Base title={title} description={description}>
  <!-- PRF-01 Hero -->
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow reveal">Proof</span>
      <h1 class="reveal">Measured before. Measured after.</h1>
      <p class="lede page-hero-sub reveal">
        Every engagement ships with its own evidence. Here&rsquo;s the work,
        told in numbers.
      </p>
    </div>
  </section>

  <!-- PRF-02 Case study grid -->
  <section class="section work-section">
    <div class="wrap">
      <p class="launch-state reveal">
        We&rsquo;re new, and we&rsquo;d rather show you one real number than
        ten vague logos. Our first engagements are in the field now. Their
        results will be published here, baselines and all.
      </p>

      <div class="case-grid">
        <!-- [PLACEHOLDER] Pilot case study card: founder to supply title,
             one-line question, and headline metric -->
        <a class="card case-card reveal" href="/work/pilot">
          <span class="case-tag mono">Pilot / In the Field</span>
          <h2 class="case-title">[PLACEHOLDER: Pilot case study. Title, one-line leak, headline metric.]</h2>
          <span class="case-link link-draw">Read the study</span>
        </a>
      </div>
    </div>
  </section>

  <!-- PRF-04 Closing CTA -->
  <CtaSection
    headline="The next number on this page could be yours."
    ctaLabel="See the assessment"
    ctaHref="/assessment"
  />
</Base>

<style>
  .page-hero {
    padding-top: calc(var(--section-pad) * 1.1);
    padding-bottom: var(--section-pad);
  }
  .page-hero h1 { max-width: 15ch; }
  .page-hero-sub { margin-top: 1.75rem; max-width: 48ch; }

  .work-section { padding-top: 0; }
  .launch-state {
    max-width: 52ch;
    color: var(--slate);
    padding-top: var(--section-pad);
    border-top: 1px solid var(--hairline);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
    gap: 1.25rem;
    margin-top: 3.5rem;
  }
  .case-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-decoration: none;
    min-height: 260px;
    padding: 2rem;
  }
  .case-tag {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .case-title { font-size: 1.25rem; line-height: 1.3; flex-grow: 1; }
  .case-link {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--signal);
    width: fit-content;
    background-size: 0% 1px;
  }
  .case-card:hover .case-link { background-size: 100% 1px; }
</style>
