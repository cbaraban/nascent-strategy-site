---
import Base from '../layouts/Base.astro';

const title = 'Book an Assessment | Nascent Strategy';
const description =
  'We help businesses find the clarity already inside them, then build what makes it useful. Kansas City, built for anywhere.';
---

<Base title={title} description={description}>
  <!-- CON-01 Hero -->
  <section class="page-hero">
    <div class="wrap">
      <span class="eyebrow reveal">Get Started</span>
      <h1 class="reveal">Tell us what you suspect is true.</h1>
      <p class="lede page-hero-sub reveal">
        A 30-minute call. No deck, no pitch theater. You tell us the thing you
        can feel but haven&rsquo;t been able to prove, and we&rsquo;ll tell you
        honestly whether the assessment can pin it down.
      </p>
    </div>
  </section>

  <!-- CON-02 Booking / form -->
  <section class="section booking-section">
    <div class="wrap grid booking-grid">
      <div class="booking-widget reveal">
        <h2 class="booking-headline">Pick a time</h2>
        <!-- [FOUNDER TO CONFIRM] Cal.com vs Calendly vs form-only at launch.
             Mount the booking embed inside this panel; wire GA4 events
             "booking widget opened" and "booking completed" in GTM. -->
        <div class="widget-slot">
          <span class="mono widget-note">[PLACEHOLDER: Cal.com or Calendly embed. Founder to confirm booking tool.]</span>
        </div>

        <!-- CON-03 Direct contact -->
        <div class="direct">
          <!-- [PLACEHOLDER] Founder to supply email and LinkedIn -->
          <p>Prefer email? <a class="link-draw" href="mailto:hello@nascentstrategy.com">[Email placeholder]</a></p>
          <p>Or find us on LinkedIn: <a class="link-draw" href="https://www.linkedin.com" rel="noopener">[LinkedIn placeholder]</a></p>
        </div>
      </div>

      <div class="booking-form reveal">
        <form
          id="contact-form"
          name="revenue-question"
          method="POST"
          action="/thanks"
          data-netlify="true"
          netlify-honeypot="website"
          novalidate
        >
          <input type="hidden" name="form-name" value="revenue-question" />
          <!-- Spam: honeypot plus time-based check (no CAPTCHA) -->
          <p class="hp" aria-hidden="true">
            <label>Website <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
          </p>
          <input type="hidden" name="started-at" id="started-at" value="" />

          <div class="field">
            <label for="f-name">Name</label>
            <input id="f-name" name="name" type="text" autocomplete="name" required />
            <p class="field-error mono" id="err-name" hidden>Tell us who to ask for.</p>
          </div>

          <div class="field">
            <label for="f-company">Company</label>
            <input id="f-company" name="company" type="text" autocomplete="organization" />
          </div>

          <div class="field">
            <label for="f-email">Email</label>
            <input id="f-email" name="email" type="email" autocomplete="email" required />
            <p class="field-error mono" id="err-email" hidden>That email doesn&rsquo;t look right. One more look?</p>
          </div>

          <div class="field">
            <label for="f-question">What do you suspect is true about your business that you haven&rsquo;t been able to prove?</label>
            <textarea id="f-question" name="question" rows="4" required></textarea>
            <p class="field-error mono" id="err-question" hidden>Even a rough version helps. One sentence is plenty.</p>
          </div>

          <button class="btn btn-primary form-submit" type="submit">
            Send it
            <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

        <div class="form-success" id="form-success" hidden tabindex="-1">
          <p class="success-headline">Got it. We&rsquo;ll reply within one business day.</p>
          <p class="success-body">
            In the meantime, <a class="link-draw" href="/method">the Method page</a>
            is the fastest way to see how we&rsquo;d approach it.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    padding-top: calc(var(--section-pad) * 1.1);
    padding-bottom: var(--section-pad);
  }
  .page-hero h1 { max-width: 13ch; }
  .page-hero-sub { margin-top: 1.75rem; max-width: 50ch; }

  .booking-section { padding-top: 0; }
  .booking-grid {
    row-gap: 3rem;
    padding-top: var(--section-pad);
    border-top: 1px solid var(--hairline);
  }
  .booking-widget { grid-column: 1 / span 5; }
  .booking-headline { font-size: var(--text-h3); }
  .widget-slot {
    margin-top: 1.5rem;
    border: 1px dashed var(--hairline);
    border-radius: var(--radius);
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .widget-note {
    font-size: 0.75rem;
    color: var(--slate);
    text-align: center;
    letter-spacing: 0.04em;
    max-width: 32ch;
  }
  .direct { margin-top: 2.5rem; color: var(--slate); }
  .direct p + p { margin-top: 0.625rem; }
  .direct a { color: var(--ink); font-weight: 600; }

  .booking-form { grid-column: 7 / -1; }

  .hp { position: absolute; left: -9999px; opacity: 0; }

  .field { margin-bottom: 1.75rem; }
  .field label {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: 0.625rem;
  }
  .field input,
  .field textarea {
    width: 100%;
    font: inherit;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: 0.875rem 1rem;
    transition: border-color var(--dur-hover) var(--ease-out);
  }
  .field input:hover, .field textarea:hover { border-color: var(--slate); }
  .field input:focus-visible, .field textarea:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 0;
    border-color: var(--signal);
  }
  .field.has-error input, .field.has-error textarea { border-color: #b3261e; }
  .field-error {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: #b3261e;
    letter-spacing: 0.02em;
  }
  textarea { resize: vertical; min-height: 120px; }

  .form-success {
    border: 1px solid var(--hairline);
    border-left: 2px solid var(--signal);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .success-headline {
    font-family: var(--font-display);
    font-variation-settings: 'opsz' 40;
    font-weight: 600;
    font-size: 1.375rem;
  }
  .success-body { margin-top: 0.875rem; color: var(--slate); }

  @media (max-width: 1023px) {
    .booking-widget, .booking-form { grid-column: 1 / -1; }
  }
</style>

<script>
  import '../scripts/contact.js';
</script>
